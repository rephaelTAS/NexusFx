<settings>
    <servers>
        <!-- GitHub Packages -->
        <server>
            <id>github</id>
            <username>SEU_GITHUB_USERNAME</username>
            <password>GITHUB_PERSONAL_ACCESS_TOKEN</password>
        </server>

        <!-- OSSRH (Maven Central) -->
